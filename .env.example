# ===== 必須 =====

# ===== LLMプロバイダ選択 =====
# anthropic（既定）または gemini。抽出・生成・対話すべてに使われる。
LLM_PROVIDER=anthropic

# --- Anthropic（Claude）を使う場合 ---
# 極秘情報を扱うため、ゼロデータリテンション(ZDR)を有効化したキーの使用を強く推奨。
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Gemini を使う場合（LLM_PROVIDER=gemini）---
# (A) 無料/低コスト枠: Google AI Studio の APIキー
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-flash-latest   # AI Studio時の既定。高精度が要れば gemini-2.5-pro
#   ※ Vertex AI では `-latest` エイリアスが使えないため、既定は gemini-2.5-flash（版付き）になる
# (B) 企業/セキュア: Vertex AI（極秘データが自社GCP内に留まる・GWS親和）
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1

# Notion（シグナルDB・ストーリーDB） — Internal Integration Token(Bearer)
# 各DBに Connections からインテグレーションを共有すること。
NOTION_TOKEN=
# database_id を設定（起動時に data_source_id へ自動解決してキャッシュする）
NOTION_SIGNAL_DB_ID=
NOTION_STORY_DB_ID=

# ===== データソース（任意 — 未設定のソースはスキップされる） =====

# --- ライフログ: Plaud NotePin S ---
# 文字起こしファイル(.txt/.md/.srt/.vtt)を置く受け皿フォルダ。
# 供給経路: (1)公式Zapier「Transcript & Summary Ready」→Drive/Dropbox同期フォルダ
#           (2)非公式CLI `plaud sync <dir>` を日次cron  (3)アプリから手動エクスポート
LIFELOG_INBOX_DIR=./lifelog-inbox
# 取り込み後に _processed/ へ退避するか。既定 true（Plaudは録音ごとに一意ファイルが
# 増えるため退避が効率的）。Drive等の同期フォルダを使うなら false 推奨。
LIFELOG_ARCHIVE=true

# --- メッセンジャー: LINE ---
# LINE の「トーク履歴を送信」でエクスポートした .txt を置く受け皿フォルダ。
# （LINE には個人トークを読む公開APIが無いため手動エクスポート方式）
#
# 摩擦を減らすコツ: Google Drive / iCloud / Dropbox の「同期フォルダ」のパスを指定すると、
# スマホで「送信」→そのフォルダに保存するだけで取り込まれる（PCへのファイル移動が不要）。
# 例) MESSENGER_INBOX_DIR=/Users/you/Library/Mobile Documents/com~apple~CloudDocs/LINE
MESSENGER_INBOX_DIR=./messenger-inbox
# 取り込んだファイルを _processed/ へ移動するか。既定 false（非破壊）。
# 同期フォルダでは false 推奨（毎回の全履歴再エクスポートでも日付単位で重複排除される）。
# ローカルの使い捨てフォルダで整理したい場合のみ true。
MESSENGER_ARCHIVE=false

# --- Slack ---
# search.messages 用。経営者本人のOAuth認可で発行したユーザートークン(xoxp-)が必要。
# 必要スコープ: search:read, users:read
SLACK_USER_TOKEN=
# 対象経営者の Slack ユーザーID（Uxxxx）
SLACK_TARGET_USER_ID=

# --- Google Workspace（Gmail / Calendar / Meet / Drive）---
# サービスアカウント + ドメイン全体委任（DWD）で対象経営者を impersonate する。
# Workspace管理コンソールでクライアントIDと readonly スコープを事前登録すること。
GOOGLE_SA_CLIENT_EMAIL=
# サービスアカウントの秘密鍵（改行は \n でエスケープして1行で記載）
GOOGLE_SA_PRIVATE_KEY=
# impersonate する対象経営者のメールアドレス
GOOGLE_TARGET_EMAIL=

# ===== 設定 =====

# 経営者の名前（対話表示・プロファイル用）
EXECUTIVE_NAME=代表取締役

# シグナルとして採用する重要度のしきい値（1〜10）。これ未満は破棄。
SIGNAL_IMPORTANCE_THRESHOLD=5

# ===== アウトプット（任意） =====

# ブリーフィング/ダイジェストをNotionにも出力する場合の親ページID。
# 未設定ならローカルの briefings/ digests/ にMarkdownのみ出力。
NOTION_BRIEFING_PARENT_PAGE_ID=
NOTION_DIGEST_PARENT_PAGE_ID=

# --- Web対話UI（npm run web）---
WEB_HOST=127.0.0.1
WEB_PORT=8787
# 設定すると /api/* に Bearer 認証を要求（要件4.1: 経営幹部のみ）。
# ローカル以外に公開する場合は必ず設定すること。
WEB_ACCESS_TOKEN=

# ===== SES案件・要員マッチング（npm run ses / ses:demo） =====
# 詳細: docs/ses-matching-basic-design.md §9 / docs/ses-matching-detailed-design.md
# ANTHROPIC_API_KEY 未設定時は自動的にdemoモード（外部呼び出しなし）で動作する。

# --- メール送受信プロバイダ切替（収集・下書き作成・サマリ送信の「口」だけを差し替える） ---
# xserver（既定・IMAP/SMTP直結。Xserver単独運用向け）| gmail（Google Workspace API・DWD）
# 会社ドメインをGoogle Workspaceへ移行したら gmail に切り替えるだけで他は変更不要。
MAIL_PROVIDER=xserver
# [xserver] 共有メーリス(sales@)を置くメールサーバのIMAP/SMTP接続情報
XSERVER_IMAP_HOST=
XSERVER_IMAP_PORT=993
XSERVER_SMTP_HOST=
XSERVER_SMTP_PORT=465
# [xserver] 共有メールボックス(sales@)のログインユーザ/パスワード（共有）
XSERVER_SHARED_USER=
XSERVER_SHARED_PASS=
# [xserver] 全員に返信の下書きをAPPENDする下書きフォルダ名（サーバの表記に合わせる）
XSERVER_DRAFTS_MAILBOX=Drafts
# [xserver] 収集対象の遡り日数（1日2回バッチ想定なので既定1日）
XSERVER_COLLECT_DAYS=1

# 粗利下限（円/月）。「案件単金上限 − 要員希望単金」がこれ未満のペアは除外。既定10万円・変更可
MIN_GROSS_MARGIN_JPY=100000
# [gmail] 収集対象（Xserverからの転送先）Gmailアドレス。空なら受信箱全体から検索
SES_TARGET_GMAIL=
# マッチング結果サマリの通知先メールアドレス
SES_NOTIFY_TO=
# 1案件あたりLLM最終判定に回す候補ペアの上限（コスト上限の保証）
MAX_CANDIDATES_PER_ITEM=5
# 必須スキル一致率の下限（0〜1・許容範囲の下端）。未満のペアは除外
SKILL_MATCH_THRESHOLD=0.6
# 「強マッチ」の下限（0〜1）。以上=成立候補、下限〜これ未満=参考提案バンド
SKILL_MATCH_STRONG_THRESHOLD=0.8
# 時給→月額換算に使う月間稼働時間
HOURLY_TO_MONTHLY_HOURS=160
# 開始時期と稼働可能日の整合判定の猶予日数
MATCH_TIMING_GRACE_DAYS=30
# 交渉提案: 粗利が下限に届かないペアを、案件+X万・要員−Y万の交渉で成立させる提案を出すか
ENABLE_NEGOTIATION=true
# 交渉で案件単金を上げてもらう上限（万円/月）
NEGOTIATION_MAX_PROJECT_RAISE_MAN=5
# 交渉で要員単金を下げてもらう上限（万円/月）
NEGOTIATION_MAX_ENGINEER_CUT_MAN=5
# Notion: 案件DB / 要員DB / マッチ結果DB（database_id。起動時にdata_source_idへ自動解決）
NOTION_PROJECT_DB_ID=
NOTION_ENGINEER_DB_ID=
NOTION_MATCH_DB_ID=
# Notion: 自社社員DB（候補要員→案件探し機能。npm run ses:own-match で参照）
NOTION_OWN_ENGINEER_DB_ID=
# Notion: マッチ評価ログDB（複数人の妥当/ズレ評価の共有の正）
NOTION_FEEDBACK_DB_ID=
# Notion: スキル同義辞書DB（人のフィードバックで育てる共有辞書）
NOTION_SKILL_EQUIV_DB_ID=
# マッチ確認UI（npm run ses:web）の待受ポート。既存の web(8787) と衝突しないよう既定8788
SES_WEB_PORT=8788
# 確認UIの待受ホスト。複数人でLAN共有する場合は 0.0.0.0 等（必ず WEB_ACCESS_TOKEN も設定）。既定はローカルのみ
SES_WEB_HOST=127.0.0.1
# 確認UIのアクセストークンは上部の WEB_ACCESS_TOKEN を使用（chat UI と共通）。
# ※ここで再宣言しないこと — dotenvは後勝ちのため、空で再宣言すると上部の設定値が消えて認証が無効になる
# 確認UIが読み書きするレビュー用ローカルJSONの置き場（バッチ/自社社員探しの成果を保存）
SES_REVIEW_DATA_DIR=data/ses-review
# 段階別モデル（抽出=Haiku・最終判定/メール生成=Sonnet。切替可能）
ANTHROPIC_MODEL_EXTRACT=claude-haiku-4-5
ANTHROPIC_MODEL_MATCH=claude-sonnet-5
# trueでBatch API（50%割引）を使用。Phase3で参照（現状未使用の予約設定）
USE_BATCH_API=false
# trueで強制demo（ANTHROPIC_API_KEYの有無に関わらず外部呼び出しゼロで実行）
DEMO_MODE=false
